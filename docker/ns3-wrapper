#!/bin/bash
# Intercepts "./ns3 run <scenario> [args]" and executes the pre-built binary
# directly.  All other subcommands (configure, build, …) go to ns3.orig.
if [ "${1:-}" = "run" ]; then
    FULL="${2:-}"; SCENARIO="${FULL%% *}"; EXTRA="${FULL#"$SCENARIO"}"
    BIN=$(find /build/ns-3-dev/build -name "*-${SCENARIO}-*" -type f -executable 2>/dev/null | head -1)
    [ -z "$BIN" ] && { echo "scenario not found: $SCENARIO" >&2; exit 1; }
    exec "$BIN" $EXTRA "${@:3}"
fi
exec /build/ns-3-dev/ns3.orig "$@"
